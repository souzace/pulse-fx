{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:create": "node-pg-migrate --tsconfig tsconfig.json -m src/infra/migrations create",
    "migrate:up": "node-pg-migrate -r dotenv/config --tsconfig tsconfig.json -m src/infra/migrations up",
    "migrate:down": "node-pg-migrate -r dotenv/config --tsconfig tsconfig.json -m src/infra/migrations down",
    "migrate:test:up": "node --env-file=.env.test ./node_modules/node-pg-migrate/bin/node-pg-migrate --tsconfig tsconfig.json -m src/infra/migrations up",
    "db:test:create": "node --env-file=.env.test -e \"require('pgtools').createdb(process.env.DATABASE_URL.replace('/pulse_fx_test', '/postgres'), 'pulse_fx_test').catch(() => {})\"",
    "pretest": "npm run db:test:create && npm run migrate:test:up",
    "test": "node --env-file=.env.test ./node_modules/jest/bin/jest.js --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "pgtools": "^1.0.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "fastify": "^5.8.5",
    "node-cron": "^4.2.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0"
  }
}
