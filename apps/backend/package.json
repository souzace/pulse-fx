{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:create": "node-pg-migrate --tsconfig tsconfig.json -m src/infra/migrations create",
    "migrate:up": "node-pg-migrate -r dotenv/config -m dist/infra/migrations up",
    "migrate:down": "node-pg-migrate -r dotenv/config -m dist/infra/migrations down",
    "migrate:test:up": "node --env-file=.env.test ./node_modules/node-pg-migrate/bin/node-pg-migrate -m dist/infra/migrations up",
    "db:test:create": "node --env-file=.env.test -e \"const { Client } = require('pg'); const c = new Client({ user: process.env.POSTGRES_USER, password: process.env.POSTGRES_PASSWORD, host: process.env.POSTGRES_HOST, port: Number(process.env.POSTGRES_PORT), database: 'postgres' }); c.connect().then(() => c.query('CREATE DATABASE \\\"' + process.env.POSTGRES_DATABASE + '\\\"')).catch(e => { if (e.code !== '42P04') throw e; }).finally(() => c.end())\"",
    "pretest": "npm run db:test:create && npm run migrate:test:up",
    "test": "node --env-file=.env.test ./node_modules/jest/bin/jest.js --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/winston": "^2.4.4",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "pgtools": "^1.0.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "axios": "^1.18.0",
    "fastify": "^5.8.5",
    "node-cron": "^4.2.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "winston": "^3.19.0"
  }
}
